# Super Browser — copy to .env and fill locally. Never commit .env.
# Signup links and step-by-step setup: docs/setup-walkthrough.md
# Agent one-liner: ./scripts/super-browser setup

SUPER_BROWSER_REPO_ROOT=

# --- Rank 1: Browser Use Cloud (anti-bot, profiles, recordings) ---
# Sign up: https://cloud.browser-use.com/
BROWSER_USE_API_KEY=

# --- Rank 2: Browserbase (docs-only — adapter gated; deliberation + SSOT only) ---
# Sign up: https://www.browserbase.com/
# BROWSERBASE_API_KEY=

# --- Rank 2: Hyperbrowser (cloud scrape jobs) ---
# Sign up: https://www.hyperbrowser.ai/
HYPERBROWSER_API_KEY=
# HYPERBROWSER_API_BASE=

# --- Rank 2: Airtop (cloud sessions, page-query, GTM) ---
# Sign up: https://www.airtop.ai/
AIRTOP_API_KEY=
# AIRTOP_API_BASE=
# AIRTOP_TIMEOUT_MINUTES=

# --- Rank 3: Steel (hosted Chromium + Playwright CDP) ---
# Sign up: https://steel.dev/
STEEL_API_KEY=
# STEEL_CDP_URL=

# --- Rank 4: Orgo (full desktop / computer-use VMs) ---
# Sign up: https://orgo.ai/ — create a computer in the dashboard, then paste its id (optional; adapter can auto-discover)
ORGO_API_KEY=
# ORGO_COMPUTER_ID=
# ORGO_API_BASE=
# ORGO_MODEL=

# --- Separate lane: Decodo residential proxy (optional; raw HTTP works without it) ---
# Sign up: https://decodo.com/
# DECODO_PROXY=http://user:pass@gate.decodo.com:7000

# --- Optional Slack daemon (super-browser agent) ---
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SUPER_BROWSER_SLACK_EXECUTE=false

# --- Runtime overrides (usually leave unset) ---
# SUPER_BROWSER_STATE_DIR=
# SUPER_BROWSER_APPROVAL_TTL_SECONDS=1800
